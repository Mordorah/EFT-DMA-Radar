<UserControl x:Class="LoneEftDmaRadar.UI.Radar.Views.PlayersTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:LoneEftDmaRadar.UI.Radar.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Padding="10">
    <d:UserControl.DataContext>
        <d:DesignInstance Type="{x:Type vm:PlayersViewModel}" IsDesignTimeCreatable="False" />
    </d:UserControl.DataContext>

    <UserControl.Resources>
        <SolidColorBrush x:Key="AccentBrush" Color="#5DA8FF" />
        <SolidColorBrush x:Key="WarnBrush" Color="#F3B04D" />
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Orientation="Vertical" Margin="0,0,0,10">

            <!-- Header -->
            <TextBlock Text="Players"
                       FontSize="16"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource Neon.PurpleSoftBrush}"
                       Margin="0,0,0,8" />

            <!-- Kill Feed Settings -->
            <GroupBox Header="Kill Feed" Margin="0,0,0,8">
                <StackPanel Margin="4">
                    <CheckBox Content="Show Kill Feed on Radar"
                              IsChecked="{Binding KillFeedEnabled, Mode=TwoWay}"
                              Margin="0,0,0,6" />
                    <DockPanel Margin="0,0,0,4">
                        <TextBlock Text="Display Duration:"
                                   VerticalAlignment="Center"
                                   Width="110" />
                        <TextBlock Text="{Binding KillFeedMaxAge, StringFormat={}{0}s}"
                                   VerticalAlignment="Center"
                                   Width="35"
                                   DockPanel.Dock="Right"
                                   TextAlignment="Right" />
                        <Slider Minimum="10" Maximum="120"
                                Value="{Binding KillFeedMaxAge, Mode=TwoWay}"
                                TickFrequency="10"
                                IsSnapToTickEnabled="True" />
                    </DockPanel>
                </StackPanel>
            </GroupBox>

            <!-- Watchlist -->
            <GroupBox Header="Watchlist" Margin="0,0,0,8">
                <StackPanel Margin="4">

                    <!-- Add form -->
                    <TextBlock Text="Add Player" FontWeight="SemiBold" Margin="0,0,0,4" />
                    <DockPanel Margin="0,0,0,4">
                        <TextBlock Text="Account ID:" VerticalAlignment="Center" Width="80" />
                        <TextBox Text="{Binding WatchlistAccountId, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="4,0,0,0" />
                    </DockPanel>
                    <DockPanel Margin="0,0,0,4">
                        <TextBlock Text="Name:" VerticalAlignment="Center" Width="80" />
                        <TextBox Text="{Binding WatchlistPlayerName, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="4,0,0,0" />
                    </DockPanel>
                    <DockPanel Margin="0,0,0,4">
                        <TextBlock Text="Reason:" VerticalAlignment="Center" Width="80" />
                        <TextBox Text="{Binding WatchlistReason, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="4,0,0,0" />
                    </DockPanel>
                    <DockPanel Margin="0,0,0,6">
                        <TextBlock Text="Tag:" VerticalAlignment="Center" Width="80" />
                        <ComboBox ItemsSource="{Binding WatchlistTags}"
                                  SelectedItem="{Binding WatchlistTag, Mode=TwoWay}"
                                  Margin="4,0,0,0"
                                  Width="120"
                                  HorizontalAlignment="Left" />
                    </DockPanel>
                    <Button Content="Add to Watchlist"
                            Click="AddWatchlist_Click"
                            HorizontalAlignment="Left"
                            Padding="12,4"
                            Margin="0,0,0,8" />

                    <!-- Watchlist entries -->
                    <DataGrid ItemsSource="{Binding WatchlistEntries}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              HeadersVisibility="Column"
                              MaxHeight="200"
                              FontSize="11"
                              GridLinesVisibility="None"
                              VerticalScrollBarVisibility="Auto">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Name" Binding="{Binding PlayerName}" Width="100" />
                            <DataGridTextColumn Header="Tag" Binding="{Binding Tag}" Width="70" />
                            <DataGridTextColumn Header="Reason" Binding="{Binding Reason}" Width="*" />
                            <DataGridTextColumn Header="Added" Binding="{Binding Added}" Width="110" />
                            <DataGridTemplateColumn Header="" Width="24">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="X"
                                                Click="RemoveWatchlist_Click"
                                                Tag="{Binding AccountId}"
                                                Padding="2,0"
                                                FontSize="10"
                                                ToolTip="Remove from watchlist" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </GroupBox>

            <!-- Player History -->
            <GroupBox Header="Player History (This Session)" Margin="0,0,0,8">
                <StackPanel Margin="4">
                    <DockPanel Margin="0,0,0,6">
                        <Button Content="Refresh"
                                Click="RefreshHistory_Click"
                                Padding="8,2"
                                HorizontalAlignment="Left" />
                        <Button Content="Clear History"
                                Click="ClearHistory_Click"
                                Padding="8,2"
                                HorizontalAlignment="Left"
                                Margin="8,0,0,0" />
                    </DockPanel>
                    <DataGrid ItemsSource="{Binding HistoryEntries}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              HeadersVisibility="Column"
                              MaxHeight="250"
                              FontSize="11"
                              GridLinesVisibility="None"
                              VerticalScrollBarVisibility="Auto">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Name" Binding="{Binding PlayerName}" Width="100" />
                            <DataGridTextColumn Header="Type" Binding="{Binding Type}" Width="60" />
                            <DataGridTextColumn Header="Side" Binding="{Binding Side}" Width="50" />
                            <DataGridTextColumn Header="Raids" Binding="{Binding Raids}" Width="40" />
                            <DataGridTextColumn Header="Last Seen" Binding="{Binding LastSeen}" Width="110" />
                            <DataGridTemplateColumn Header="" Width="24">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="+"
                                                Click="WatchFromHistory_Click"
                                                Padding="2,0"
                                                FontSize="10"
                                                ToolTip="Add to watchlist" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </GroupBox>

        </StackPanel>
    </ScrollViewer>
</UserControl>
