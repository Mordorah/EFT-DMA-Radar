<UserControl x:Class="LoneEftDmaRadar.UI.Radar.Views.MemWritesTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:LoneEftDmaRadar.UI.Radar.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Padding="10">
    <d:UserControl.DataContext>
        <d:DesignInstance Type="{x:Type vm:MemWritesViewModel}" IsDesignTimeCreatable="False" />
    </d:UserControl.DataContext>

    <UserControl.Resources>
        <SolidColorBrush x:Key="AccentBrush" Color="#5DA8FF" />
        <SolidColorBrush x:Key="WarningBrush" Color="#F3B04D" />
        <SolidColorBrush x:Key="DangerBrush" Color="#EF596F" />
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Orientation="Vertical" Margin="0,0,0,10">

            <!-- Transparent header -->
            <TextBlock Text="Memory Writes"
                       FontSize="16"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource Neon.PurpleSoftBrush}"
                       Margin="0,0,0,4" />

            <!-- Critical Warning banner -->
            <Border Background="#0C11151F"
                    BorderBrush="{StaticResource DangerBrush}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="12"
                    Margin="0,0,0,8">
                <DockPanel>
                    <Border Background="{StaticResource DangerBrush}"
                            Width="3"
                            CornerRadius="2"
                            DockPanel.Dock="Left" />
                    <StackPanel Margin="12,0,0,0">
                        <TextBlock Text="Memory writes are high risk"
                                   FontWeight="SemiBold"
                                   FontSize="14" />
                        <TextBlock TextWrapping="Wrap"
                                   Foreground="{DynamicResource App.TextMutedBrush}"
                                   Margin="0,4,0,0"
                                   FontSize="12">
                            These features modify game memory directly and are easy to flag. Proceed only if you accept the risk.
                        </TextBlock>
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- Master toggle (transparent) -->
            <CheckBox Content="Enable Memory Writes"
                      IsChecked="{Binding Enabled, Mode=TwoWay}"
                      FontWeight="SemiBold"
                      FontSize="14"
                      Margin="0,4,0,12" />

            <UniformGrid Columns="2" Rows="0" Margin="0,0,0,8">

                <!-- Silent Aim card -->
                <GroupBox Header="Silent Aim" Margin="0,0,8,8">
                    <StackPanel IsEnabled="{Binding Enabled}">
                        <CheckBox Content="Enable Silent Aim"
                                  IsChecked="{Binding MemoryAimEnabled, Mode=TwoWay}"
                                  FontWeight="SemiBold"
                                  Margin="0,0,0,8" />

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <TextBlock Text="Target bone:"
                                       VerticalAlignment="Center"
                                       Margin="0,0,8,0" />
                            <ComboBox ItemsSource="{Binding AvailableBones}"
                                      SelectedItem="{Binding MemoryAimTargetBone, Mode=TwoWay}"
                                      Width="200" />
                        </StackPanel>

                        <TextBlock Text="Writes shot direction in memory instead of moving the mouse. Shares the same aim key as Device Aimbot."
                                   TextWrapping="Wrap"
                                   Foreground="{DynamicResource App.TextMutedBrush}"
                                   FontSize="12"
                                   Margin="0,0,0,8" />

                        <Border Background="#0C1A1618"
                                BorderBrush="{StaticResource DangerBrush}"
                                BorderThickness="0.5"
                                CornerRadius="6"
                                Padding="10"
                                Margin="0,4,0,0">
                            <StackPanel>
                                <TextBlock Text="Detection risk: very high"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource DangerBrush}" />
                                <TextBlock Text="Silent aim behavior is extremely obvious to anti-cheat systems."
                                           TextWrapping="Wrap"
                                           Foreground="{DynamicResource App.TextMutedBrush}"
                                           FontSize="12"
                                           Margin="0,4,0,0" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </GroupBox>

                <!-- No Recoil card -->
                <GroupBox Header="No Recoil" Margin="0,0,0,8">
                    <StackPanel IsEnabled="{Binding Enabled}">
                        <CheckBox Content="Enable No Recoil"
                                  IsChecked="{Binding NoRecoilEnabled, Mode=TwoWay}"
                                  FontWeight="SemiBold"
                                  Margin="0,0,0,8" />

                        <TextBlock Text="Adjust recoil and sway written into memory. 100% removes recoil; 0% keeps it stock."
                                   TextWrapping="Wrap"
                                   Foreground="{DynamicResource App.TextMutedBrush}"
                                   FontSize="12"
                                   Margin="0,0,0,8" />

                        <StackPanel Margin="0,4,0,0" IsEnabled="{Binding NoRecoilEnabled}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="160" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Recoil reduction" />
                                <TextBlock Text="{Binding NoRecoilAmount, StringFormat='{}{0:F0}%'}"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource AccentBrush}"
                                           Grid.Column="1"
                                           HorizontalAlignment="Right" />
                            </Grid>
                            <Slider Value="{Binding NoRecoilAmount, Mode=TwoWay}"
                                    Minimum="0"
                                    Maximum="100"
                                    TickFrequency="5"
                                    IsSnapToTickEnabled="True"
                                    Margin="0,6,0,0" />
                        </StackPanel>

                        <StackPanel Margin="0,10,0,0" IsEnabled="{Binding NoRecoilEnabled}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="160" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Sway reduction" />
                                <TextBlock Text="{Binding NoSwayAmount, StringFormat='{}{0:F0}%'}"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource AccentBrush}"
                                           Grid.Column="1"
                                           HorizontalAlignment="Right" />
                            </Grid>
                            <Slider Value="{Binding NoSwayAmount, Mode=TwoWay}"
                                    Minimum="0"
                                    Maximum="100"
                                    TickFrequency="5"
                                    IsSnapToTickEnabled="True"
                                    Margin="0,6,0,0" />
                        </StackPanel>

                        <Border Background="#0C1A1618"
                                BorderBrush="{StaticResource WarningBrush}"
                                BorderThickness="0.5"
                                CornerRadius="6"
                                Padding="10"
                                Margin="0,10,0,0">
                            <StackPanel>
                                <TextBlock Text="Detection risk: high"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource WarningBrush}" />
                                <TextBlock Text="Directly changes weapon behavior in memory and is simple to flag."
                                           TextWrapping="Wrap"
                                           Foreground="{DynamicResource App.TextMutedBrush}"
                                           FontSize="12"
                                           Margin="0,4,0,0" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </GroupBox>

                <!-- Infinite Stamina card -->
                <GroupBox Header="Infinite Stamina" Margin="0,0,8,8">
                    <StackPanel IsEnabled="{Binding Enabled}">
                        <CheckBox Content="Enable Infinite Stamina"
                                  IsChecked="{Binding InfiniteStaminaEnabled, Mode=TwoWay}"
                                  FontWeight="SemiBold"
                                  Margin="0,0,0,8" />

                        <TextBlock Text="Refills stamina and oxygen when they drop below roughly one-third. Also attempts to bypass fatigue states."
                                   TextWrapping="Wrap"
                                   Foreground="{DynamicResource App.TextMutedBrush}"
                                   FontSize="12"
                                   Margin="0,0,0,8" />

                        <Border Background="#0C1A1618"
                                BorderBrush="{StaticResource WarningBrush}"
                                BorderThickness="0.5"
                                CornerRadius="6"
                                Padding="10"
                                Margin="0,4,0,0">
                            <StackPanel>
                                <TextBlock Text="Detection risk: medium"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource WarningBrush}" />
                                <TextBlock Text="Player stat changes are less blatant than recoil removal but remain detectable."
                                           TextWrapping="Wrap"
                                           Foreground="{DynamicResource App.TextMutedBrush}"
                                           FontSize="12"
                                           Margin="0,4,0,0" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </GroupBox>

                <!-- Anti-AFK card -->
                <GroupBox Header="Anti-AFK" Margin="0,0,0,8">
                    <StackPanel IsEnabled="{Binding Enabled}">
                        <CheckBox Content="Enable Anti-AFK"
                                  IsChecked="{Binding AntiAfkEnabled, Mode=TwoWay}"
                                  FontWeight="SemiBold"
                                  Margin="0,0,0,8" />

                        <TextBlock Text="Prevents AFK timeout by setting a 7-day inactivity delay. Applied once per raid."
                                   TextWrapping="Wrap"
                                   Foreground="{DynamicResource App.TextMutedBrush}"
                                   FontSize="12" />
                    </StackPanel>
                </GroupBox>

                <!-- Fast Weapon Ops card -->
                <GroupBox Header="Fast Weapon Ops" Margin="0,0,8,8">
                    <StackPanel IsEnabled="{Binding Enabled}">
                        <CheckBox Content="Enable Fast Weapon Ops"
                                  IsChecked="{Binding FastWeaponOpsEnabled, Mode=TwoWay}"
                                  FontWeight="SemiBold"
                                  Margin="0,0,0,8" />

                        <TextBlock Text="Speeds up reload, chamber, and other weapon animations (4x). Also increases aiming speed."
                                   TextWrapping="Wrap"
                                   Foreground="{DynamicResource App.TextMutedBrush}"
                                   FontSize="12"
                                   Margin="0,0,0,8" />

                        <Border Background="#0C1A1618"
                                BorderBrush="{StaticResource WarningBrush}"
                                BorderThickness="0.5"
                                CornerRadius="6"
                                Padding="10"
                                Margin="0,4,0,0">
                            <StackPanel>
                                <TextBlock Text="Detection risk: high"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource WarningBrush}" />
                                <TextBlock Text="Abnormal animation speeds are easily flagged."
                                           TextWrapping="Wrap"
                                           Foreground="{DynamicResource App.TextMutedBrush}"
                                           FontSize="12"
                                           Margin="0,4,0,0" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </GroupBox>

                <!-- Mag Drills card -->
                <GroupBox Header="Mag Drills" Margin="0,0,0,8">
                    <StackPanel IsEnabled="{Binding Enabled}">
                        <CheckBox Content="Enable Fast Mag Drills"
                                  IsChecked="{Binding MagDrillsEnabled, Mode=TwoWay}"
                                  FontWeight="SemiBold"
                                  Margin="0,0,0,8" />

                        <TextBlock Text="Increases magazine load and unload speed via the SkillManager."
                                   TextWrapping="Wrap"
                                   Foreground="{DynamicResource App.TextMutedBrush}"
                                   FontSize="12" />
                    </StackPanel>
                </GroupBox>

                <!-- Disable Head Bobbing card -->
                <GroupBox Header="Disable Head Bobbing" Margin="0,0,8,8">
                    <StackPanel IsEnabled="{Binding Enabled}">
                        <CheckBox Content="Disable Head Bobbing"
                                  IsChecked="{Binding DisableHeadBobbingEnabled, Mode=TwoWay}"
                                  FontWeight="SemiBold"
                                  Margin="0,0,0,8" />

                        <TextBlock Text="Removes camera head bob effect by writing to the game settings. Purely visual QoL."
                                   TextWrapping="Wrap"
                                   Foreground="{DynamicResource App.TextMutedBrush}"
                                   FontSize="12" />
                    </StackPanel>
                </GroupBox>

                <!-- Disable Inventory Blur card -->
                <GroupBox Header="Disable Inventory Blur" Margin="0,0,0,8">
                    <StackPanel IsEnabled="{Binding Enabled}">
                        <CheckBox Content="Disable Inventory Blur"
                                  IsChecked="{Binding DisableInventoryBlurEnabled, Mode=TwoWay}"
                                  FontWeight="SemiBold"
                                  Margin="0,0,0,8" />

                        <TextBlock Text="Removes the blur effect when opening inventory for a clearer view."
                                   TextWrapping="Wrap"
                                   Foreground="{DynamicResource App.TextMutedBrush}"
                                   FontSize="12" />
                    </StackPanel>
                </GroupBox>

                <!-- Time of Day card -->
                <GroupBox Header="Time of Day" Margin="0,0,8,8">
                    <StackPanel IsEnabled="{Binding Enabled}">
                        <CheckBox Content="Lock Time of Day"
                                  IsChecked="{Binding TimeOfDayEnabled, Mode=TwoWay}"
                                  FontWeight="SemiBold"
                                  Margin="0,0,0,8" />

                        <TextBlock Text="Locks the in-game time to the selected hour. Disabled on Factory and Labs."
                                   TextWrapping="Wrap"
                                   Foreground="{DynamicResource App.TextMutedBrush}"
                                   FontSize="12"
                                   Margin="0,0,0,8" />

                        <StackPanel Margin="0,4,0,0" IsEnabled="{Binding TimeOfDayEnabled}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="160" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Hour" />
                                <TextBlock Text="{Binding TimeOfDayHour, StringFormat='{}{0:F0}:00'}"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource AccentBrush}"
                                           Grid.Column="1"
                                           HorizontalAlignment="Right" />
                            </Grid>
                            <Slider Value="{Binding TimeOfDayHour, Mode=TwoWay}"
                                    Minimum="0"
                                    Maximum="24"
                                    TickFrequency="1"
                                    IsSnapToTickEnabled="True"
                                    Margin="0,6,0,0" />
                        </StackPanel>
                    </StackPanel>
                </GroupBox>

            </UniformGrid>

        </StackPanel>
    </ScrollViewer>
</UserControl>
